# ── Required secrets ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running docker-compose.

# Session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-generate-a-strong-random-secret

# Google OAuth credentials (from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Optional
MINIMAX_API_KEY=

# Email notifications (Gmail App Password — not account password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_FROM_EMAIL=yourapp@gmail.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Infrastructure (override for production) ──────────────────────────────────
# Frontend URL (used for CORS + OAuth redirect)
FRONTEND_URL=http://localhost:3000
# Google OAuth redirect (must match Google Console)
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback
# Database — SQLite for local, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./etsy_agent.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Persistent image storage path (local mode)
STORAGE_PATH=./storage

# ── Cloudflare R2 (production image storage) ──────────────────────────────────
# Leave blank to use local storage
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Cross-domain auth (production) ───────────────────────────────────────────
# Cookie domain for cross-origin cookies (e.g., .yourdomain.com)
COOKIE_DOMAIN=
# Additional CORS origins (comma-separated, e.g., https://app.yourdomain.com)
EXTRA_CORS_ORIGINS=

# ── Tunable limits (optional — defaults shown) ────────────────────────────────
LOG_LEVEL=info
RATE_LIMIT_API_KEY_RPM=60
RATE_LIMIT_USER_RPM=30
RATE_LIMIT_ANON_RPM=10
